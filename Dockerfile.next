# =============================================================================
# Stage 1: Next.js frontend build
# =============================================================================
FROM node:20-alpine AS nextjs-build

WORKDIR /frontend

COPY frontend/package*.json ./
RUN npm ci --prefer-offline

COPY frontend .

ENV AUTH_SECRET=build-time-placeholder \
    NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# =============================================================================
# Stage 2: Backend base (needed for final stage)
# =============================================================================
FROM python:3.12-alpine AS base

# =============================================================================
# Stage 3: Final image
# =============================================================================
FROM base AS final

# Python virtual environment
ENV VIRTUAL_ENV=/opt/venv
RUN python3 -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Install Python packages
RUN pip install --upgrade pip && \
    pip install --no-cache-dir \
    psutil \
    paho-mqtt \
    fastapi \
    python-dotenv \
    pydantic \
    pydantic-settings \
    "uvicorn[standard]" \
    flask \
    flask-cors \
    pytz \
    statistics \
    python-multipart \
    "passlib[bcrypt]" \
    python-jwt \
    PyJWT \
    slowapi \
    secure \
    python-decouple \
    starlette-context \
    structlog \
    python-json-logger \
    aiofiles \
    types-aiofiles \
    typing-extensions \
    "sqlalchemy[asyncio]>=2.0.30" \
    "aiosqlite>=0.20.0" \
    "alembic>=1.13.0" \
    "httpx>=0.27.0" \
    "websockets>=12.0" \
    "apscheduler>=3.10.0"

RUN pip install --no-cache-dir \
    cryptography \
    pyOpenSSL \
    "python-jose[cryptography]"

RUN pip install --no-cache-dir \
    fastapi-jwt-auth \
    fastapi-limiter

# Create mosquitto user
RUN addgroup -g 8888 mosquitto && adduser -u 8888 -G mosquitto -s /bin/sh -D mosquitto

# Install supervisord, mosquitto, node and python
RUN apk add --no-cache mosquitto supervisor nodejs python3 py3-pip

# Create all required directories
RUN mkdir -p \
    /run/supervisor \
    /etc/supervisor/conf.d \
    /app \
    /app/jwt \
    /var/log/api \
    /var/log/mosquitto \
    /var/log/supervisor \
    /etc/mosquitto/conf.d \
    /var/lib/mosquitto/db \
    /tmp/mosquitto_backups \
    /tmp/dynsec_backups \
    /nextjs/data \
    /var/lib/history && \
    touch /etc/mosquitto/mosquitto_passwd && \
    chmod 644 /etc/mosquitto/mosquitto_passwd

# Configure supervisord
COPY supervisord-next.conf /etc/supervisor/conf.d/supervisord.conf

# Copy backend config and source
COPY backend/mosquitto/config/mosquitto.conf /etc/mosquitto/mosquitto.conf
COPY backend/etc/mosquitto/conf.d/ /etc/mosquitto/conf.d/
COPY backend/app /app
RUN touch /app/monitor/__init__.py
COPY backend/mosquitto/dynsec/dynamic-security.json /var/lib/mosquitto/dynamic-security.json

# Store defaults separately so start.sh can restore them when bind mounts are used
RUN mkdir -p /defaults/mosquitto/conf.d /defaults/mosquitto_data
COPY backend/mosquitto/config/mosquitto.conf /defaults/mosquitto/mosquitto.conf
COPY backend/etc/mosquitto/conf.d/ /defaults/mosquitto/conf.d/
COPY backend/mosquitto/dynsec/dynamic-security.json /defaults/mosquitto_data/dynamic-security.json

# Copy config-env script
COPY config-env.sh /docker-entrypoint.d/
RUN chmod +x /docker-entrypoint.d/config-env.sh

# Copy Next.js standalone output
COPY --from=nextjs-build /frontend/.next/standalone /nextjs/
COPY --from=nextjs-build /frontend/.next/static /nextjs/.next/static
COPY --from=nextjs-build /frontend/public /nextjs/public

# Set permissions
RUN chown -R mosquitto:mosquitto /var/lib/mosquitto && \
    chmod -R 775 /var/lib/mosquitto && \
    chown -R root:root /app && \
    chmod -R 755 /app && \
    chown mosquitto:mosquitto /etc/mosquitto/mosquitto_passwd && \
    chmod 664 /etc/mosquitto/mosquitto_passwd && \
    chown -R mosquitto:root /var/log/mosquitto && \
    chmod -R 644 /var/log/mosquitto && \
    chmod 755 /var/log/mosquitto && \
    chown -R mosquitto:mosquitto /etc/mosquitto && \
    chmod -R 755 /etc/mosquitto && \
    chmod 644 /etc/mosquitto/mosquitto.conf && \
    chmod -R 755 /var/log/supervisor && \
    chmod -R 755 /var/log/api && \
    chmod -R 755 /nextjs && \
    chmod 755 /tmp/mosquitto_backups && \
    chmod 755 /tmp/dynsec_backups

# Environment defaults
ENV MQTT_BROKER=localhost \
    MQTT_PORT=1900 \
    MQTT_USERNAME=admin \
    MQTT_PASSWORD=admin@123 \
    JWT_SECRET=default_jwt_secret_replace_in_production \
    API_KEY=default_api_key_replace_in_production \
    HOST_ADDRESS=localhost \
    FRONTEND_URL=http://localhost:2000 \
    ALLOWED_ORIGINS=* \
    ALLOWED_HOSTS=* \
    RATE_LIMIT_PER_MINUTE=100 \
    LOG_LEVEL=INFO \
    API_LOG_FILE=/var/log/api/api_activity.log \
    MOSQUITTO_PASSWD_PATH=/etc/mosquitto/mosquitto_passwd \
    MOSQUITTO_CONF_PATH=/etc/mosquitto/mosquitto.conf \
    MOSQUITTO_BACKUP_DIR=/tmp/mosquitto_backups \
    CONFIG_API_PORT=1005 \
    DYNSEC_PATH=/var/lib/mosquitto/dynamic-security.json \
    MAX_UPLOAD_SIZE=10485760 \
    PYTHONPATH=/app/monitor \
    NODE_ENV=production \
    BROKER_LOG_PATH=/var/log/mosquitto/mosquitto.log \
    CLIENT_LOG_PATH=/var/log/api/api_activity.log \
    BUNKERAI_API_KEY="" \
    BUNKERAI_WS_URL="wss://api.bunkerai.dev/connect"

# Startup script
COPY start.sh /start.sh
RUN chmod +x /start.sh

EXPOSE 2000 1900

CMD ["/bin/sh", "-c", "/docker-entrypoint.d/config-env.sh && /start.sh"]
