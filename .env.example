# BunkerM Docker Compose Environment Variables
# Copy this file to .env and update the values before running docker compose up
#
#   cp .env.example .env
#
# IMPORTANT: Generate strong random values for all secrets in production.
# You can use: openssl rand -base64 64

# MQTT Broker Credentials
MQTT_USERNAME=admin
MQTT_PASSWORD=2UbhHYRw

# Backend API Key (shared secret between frontend and backend services)
API_KEY=replace_with_a_strong_random_key

# JWT Secret (used for backend token signing)
JWT_SECRET=replace_with_a_strong_random_secret

# Next.js Auth Secret (used for user session cookies)
AUTH_SECRET=replace_with_a_strong_random_secret
